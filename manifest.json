{
  "manifest_version": 3,
  "name": "GTS NR1 Utils",
  "description": "GTS utilities for NR1",
  "version": "1.8.15",
  "permissions": [
    "webNavigation",
    "tabs",
    "sidePanel",
    "scripting",
    "cookies"
  ],
  "host_permissions": [
    "https://*.newrelic.com/*"
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "GTS NR1 Utils"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.newrelic.com/*"
      ],
      "js": ["scripts/early-wrap.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://*.newrelic.com/*"
      ],
      "js": ["scripts/content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["scripts/page-script.js"],
      "matches": ["https://*.newrelic.com/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
